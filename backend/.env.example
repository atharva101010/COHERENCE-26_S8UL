# FlowReach AI Environment Variables

# Backend port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Groq API Key (for AI message generation)
GROQ_API_KEY=

# Email (SMTP) configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Daily send limit
DAILY_SEND_LIMIT=50
